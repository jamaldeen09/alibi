{
    "extends": "../../tsconfig.json",
    "compilerOptions": {
      "baseUrl": ".",
      "outDir": "./dist",
      "declaration": true,
      "declarationMap": true,
      "paths": {
        "@alibi/database": ["../../packages/database/src/index.ts"],
        "@alibi/database/*": ["../../packages/database/src/*"],

        "@alibi/agents": ["../../packages/agents/src/index.ts"],
