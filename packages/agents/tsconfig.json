{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "declarationMap": true,
  },
  "paths": {
    "@alibi/types": [
      "../../packages/types/src/index.ts"
    ],
    "@alibi/types/*": [
      "../../packages/types/src/*"
    ],
  },
  "include": [
    "./src/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}